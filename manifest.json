{
  "manifest_version": 3,
  "name": "Sky White Trip Logistics & Cost Auditor",
  "version": "1.0.0",
  "description": "Professional travel logistics assistant for Jabodetabek — powered by Sky White Rent Car. Optimize routes, audit toll & fuel costs, and get smart vehicle recommendations.",
  "homepage_url": "https://www.skywhiterentcar.com/",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://maps.googleapis.com/*"
  ],
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Sky White Trip Auditor | Sky White Rent Car",
    "default_icon": {
      "16": "dist/icons/icon-16.png",
      "48": "dist/icons/icon-48.png",
      "128": "dist/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "dist/icons/icon-16.png",
    "48": "dist/icons/icon-48.png",
    "128": "dist/icons/icon-128.png"
  },
  "background": {
    "scripts": [
      "dist/service-worker.js"
    ],
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "trip-auditor@skywhiterentcar.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
